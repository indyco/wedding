# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# HTTP port the app listens on
PORT=3000

# development | production
# `production` enables secure (HTTPS-only) session cookies — set it when running behind Cloudflare.
NODE_ENV=development

# Secret used to sign session cookies. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# First-run admin bootstrap. The admin account is created once from these values on first start.
# Use a long, machine-generated password. Credentials can be changed later in the dashboard
# (or via `npm run reset-admin` on the server).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-run

# Resend (https://resend.com): create an API key and verify your sending domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The From address must use a domain you've verified in Resend.
EMAIL_FROM=The Happy Couple <rsvp@yourdomain.tld>

# Public base URL used to build links inside emails (confirmation / edit-your-RSVP).
# Keep as localhost during development; set to the real https URL at the very end.
APP_BASE_URL=http://localhost:3000

# Optional: override the SQLite database location (defaults to ./data/wedding.db)
# DB_PATH=./data/wedding.db
